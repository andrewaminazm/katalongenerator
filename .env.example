# Backend (server/)
PORT=8787

# Headful Playwright recorder: log every raw step to server console (1/true/yes)
# RECORD_RECORDER_DEBUG=1

# Playwright script → DSL parser: log each parsed op (PARSED STEP: …)
# PARSE_PLAYWRIGHT_DEBUG=1

# Ollama HTTP API (default matches Ollama installer)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Default model when client does not send one
OLLAMA_MODEL=llama3.2

# Google Gemini (optional — set to enable "Gemini" in the UI; key never leaves the server)
GEMINI_API_KEY=
# Default Gemini model id when client does not send one (e.g. gemini-2.0-flash, gemini-1.5-flash)
GEMINI_MODEL=gemini-2.0-flash

# Jira: credentials come from the web UI (Jira tab). TLS for server → Jira HTTPS:
# JIRA_CA_BUNDLE must be issuing/root CAs that sign Jira’s certificate — not the server “leaf” .pem alone.
# Example (this repo): server/certs/jira-gosi-trust-chain.pem for GOSI Jira (Root + Prod Issuing CA).
# JIRA_TLS_INSECURE=1                             # dev only: skip TLS verification for Jira calls
# Or set NODE_EXTRA_CA_CERTS before starting Node (global; see Node.js docs).
